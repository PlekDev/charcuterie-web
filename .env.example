# Charcutería Gourmet — variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.

# --- Supabase ---
# URL base del proyecto (sin /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# anon key — pública por diseño, segura para el navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
# service_role key — SECRETA, solo backend. Nunca en código del navegador.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- AWS Cognito (Fase 2: autenticación) ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
