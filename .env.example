# Charcutería Gourmet — variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.

# --- Supabase ---
# URL base del proyecto (sin /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# anon key — pública por diseño, segura para el navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
# service_role key — SECRETA, solo backend. Nunca en código del navegador.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- AWS Cognito (Fase 2: autenticación) ---
# Estas vars son del SERVIDOR (sin prefijo NEXT_PUBLIC_): nunca llegan al bundle.
COGNITO_REGION=us-west-2
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# SECRETO. Necesario para calcular el SECRET_HASH en /api/auth/*. Solo backend.
COGNITO_CLIENT_SECRET=

# --- Despliegue (Docker + Cloudflare Tunnel) ---
# Token del named tunnel (Zero Trust > Tunnels). El ingress hostname ->
# http://app:3000 se configura en el dashboard de Cloudflare.
TUNNEL_TOKEN=
